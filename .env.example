# Copy this file to .env and fill in your values from the Supabase dashboard
# (Project Settings > API). These are safe to ship in the app bundle —
# the anon key is public by design; Row Level Security protects the data.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# RevenueCat public SDK keys (subscriptions — leave blank until store products
# are configured; the app runs without them, purchases just stay disabled)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
# Web Billing PUBLIC key (app.bidreel.io). Enable Web Billing in RevenueCat +
# connect Stripe, then paste the web key here to turn on web subscriptions.
# Blank = web keeps pointing users to the mobile app (safe default).
EXPO_PUBLIC_REVENUECAT_WEB_KEY=

# PostHog analytics (optional — leave blank to disable; key starts with "phc_")
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Public proposal page base — must match the edge functions' PUBLIC_PROPOSAL_BASE
EXPO_PUBLIC_SHARE_BASE_URL=https://bidreel.io/p/
