{
  "expo": {
    "name": "BidReel",
    "slug": "bidreel",
    "version": "1.0.0",
    "scheme": "bidreel",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.amerifilms.bidreel",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.amerifilms.bidreel",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#212121"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#F5B82E"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "BidReel uses your photos so you can add your studio logo to proposals."
        }
      ],
      "./plugins/withFmtConstevalFix"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "53b82e73-42a1-4e05-b681-17222f55f10e"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/53b82e73-42a1-4e05-b681-17222f55f10e"
    }
  }
}
